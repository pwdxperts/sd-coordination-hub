generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("public_reporter")
  phone         String?
  department    String?
  province      String?
  municipality  String?
  active        Boolean   @default(true)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  lastLogin     DateTime?
  lastLoginIp   String?
  mfaVerified   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedCases Case[]      @relation("CaseAssignee")
  ownedCases    Case[]      @relation("CaseOwner")
  auditLogs     AuditLog[]
  notifications Notification[]
  commentItems  CaseComment[]
  assignedTasks Task[]      @relation("TaskAssignee")
  createdTasks  Task[]      @relation("TaskCreator")
  nextStepTasks Task[]      @relation("TaskNextAssignee")

  @@map("users")
}

model Province {
  id        String     @id @default(uuid())
  name      String     @unique
  code      String?
  districts District[]
  cases     Case[]
  @@map("provinces")
}

model District {
  id             String          @id @default(uuid())
  name           String
  provinceId     String
  province       Province        @relation(fields: [provinceId], references: [id])
  municipalities Municipality[]
  cases          Case[]
  @@unique([name, provinceId])
  @@map("districts")
}

model Municipality {
  id         String   @id @default(uuid())
  name       String
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  wardCount  Int      @default(0)
  cases      Case[]
  @@unique([name, districtId])
  @@map("municipalities")
}

model Sector {
  id               String            @id @default(uuid())
  name             String            @unique
  description      String?
  active           Boolean           @default(true)
  cases            Case[]
  failureCategories FailureCategory[]
  @@map("sectors")
}

model FailureCategory {
  id          String  @id @default(uuid())
  name        String
  sectorId    String
  sector      Sector  @relation(fields: [sectorId], references: [id])
  description String?
  cases       Case[]
  @@unique([name, sectorId])
  @@map("failure_categories")
}

model Department {
  id        String  @id @default(uuid())
  name      String  @unique
  sphere    String  @default("National")
  sector    String?
  active    Boolean @default(true)
  cases     Case[]
  @@map("departments")
}

model MfaSession {
  id        String   @id @default(uuid())
  userId    String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@map("mfa_sessions")
}

model Case {
  id                      String    @id @default(uuid())
  referenceNumber         String    @unique
  title                   String
  description             String?
  intakeChannel           String    @default("manual")
  reporterName            String?
  reporterContact         String?
  reporterType            String?
  dateReceived            DateTime  @default(now())
  provinceId              String?
  province                Province? @relation(fields: [provinceId], references: [id])
  districtId              String?
  district                District? @relation(fields: [districtId], references: [id])
  municipalityId          String?
  municipality            Municipality? @relation(fields: [municipalityId], references: [id])
  ward                    String?
  latitude                Float?
  longitude               Float?
  sectorId                String?
  sector                  Sector?   @relation(fields: [sectorId], references: [id])
  failureCategoryId       String?
  failureCategory         FailureCategory? @relation(fields: [failureCategoryId], references: [id])
  subCategory             String?
  rootCause               String?
  severityScore           Int       @default(0)
  severityLevel           String    @default("Moderate")
  severityOverride        Boolean   @default(false)
  severityOverrideReason  String?
  populationAffected      Int       @default(0)
  publicSafetyRisk        Boolean   @default(false)
  durationDays            Int       @default(0)
  isRecurring             Boolean   @default(false)
  protestMediaFlag        Boolean   @default(false)
  responsibleSphere       String?
  departmentId            String?
  leadDepartment          Department? @relation(fields: [departmentId], references: [id])
  implementingAgent       String?
  accountableOfficial     String?
  contactDetails          String?
  status                  String    @default("new_submission")
  slaDeadline             DateTime?
  escalationLevel         String?   @default("none")
  lastUpdated             DateTime  @updatedAt
  assignedToId            String?
  assignedTo              User?     @relation("CaseAssignee", fields: [assignedToId], references: [id])
  reassignReason          String?
  reassignedAt            DateTime?
  reassignedFromId        String?
  ownerId                 String?
  owner                   User?     @relation("CaseOwner", fields: [ownerId], references: [id])
  actionPlan              String?
  actionPlanDueDate       DateTime?
  actionPlanSubmittedAt   DateTime?
  interventionPlan        String?
  progressPercent         Int       @default(0)
  blockers                String?
  resolutionNotes         String?
  resolutionVerifiedAt    DateTime?
  verifiedById            String?
  closeOutStatus          String?
  dateResolved            DateTime?
  lessonsLearned          String?
  linkedCaseId            String?
  duplicatedFromId        String?
  isDuplicate             Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  evidence     Evidence[]
  comments     CaseComment[]
  auditLogs    AuditLog[]
  escalations  Escalation[]
  milestones   Milestone[]
  tasks        Task[]
  @@index([status])
  @@index([severityLevel])
  @@index([provinceId])
  @@index([sectorId])
  @@index([assignedToId])
  @@index([escalationLevel])
  @@index([createdAt])
  @@map("cases")
}

model Task {
  id              String    @id @default(uuid())
  title           String
  description     String?
  status          String    @default("pending")
  priority        String    @default("medium")
  category        String?
  assignedToId    String?
  assignedTo      User?     @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById     String?
  createdBy       User?     @relation("TaskCreator", fields: [createdById], references: [id])
  caseId          String?
  case            Case?     @relation(fields: [caseId], references: [id])
  dueDate         DateTime?
  completedAt     DateTime?
  notes           String?
  nextStep        String?
  nextAssigneeId  String?
  nextAssignee    User?     @relation("TaskNextAssignee", fields: [nextAssigneeId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([assignedToId])
  @@index([status])
  @@index([caseId])
  @@map("tasks")
}

model Milestone {
  id          String    @id @default(uuid())
  caseId      String
  case        Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      String    @default("pending")
  assignedTo  String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  @@map("milestones")
}

model Evidence {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  uploadedBy  String?
  description String?
  createdAt   DateTime @default(now())
  @@map("evidence")
}

model CaseComment {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  comment   String
  createdAt DateTime @default(now())
  @@map("case_comments")
}

model AuditLog {
  id        String   @id @default(uuid())
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  action    String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  comment   String?
  metadata  String?
  ipAddress String?
  createdAt DateTime @default(now())
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Escalation {
  id            String    @id @default(uuid())
  caseId        String
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  level         String    @default("L1")
  escalatedTo   String?
  reason        String?
  status        String    @default("active")
  response      String?
  respondedBy   String?
  respondedAt   DateTime?
  escalatedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  @@map("escalations")
}

model SlaConfig {
  id                  String   @id @default(uuid())
  severityLevel       String   @unique
  responseTimeHours   Int
  resolutionDays      Int
  escalationAfterHours Int
  description         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@map("sla_configs")
}

model EscalationRule {
  id          String   @id @default(uuid())
  name        String
  condition   String
  severityMin String
  escalateTo  String
  afterHours  Int
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("escalation_rules")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String?
  type      String    @default("info")
  read      Boolean   @default(false)
  caseId    String?
  createdAt DateTime  @default(now())
  @@map("notifications")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt
  @@map("system_configs")
}
